          },
          {
            "segment": {
              "startIndex": 1268,
              "endIndex": 1386,
              "text": "*   **Budget-Friendly:** It is significantly cheaper because it doesn't require a blood draw or centrifuge processing."
            },
            "groundingChunkIndices": [

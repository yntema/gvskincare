    {
      "@type": "FAQPage",
      "@id": "https://www.gvskincare.com/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Where is GV Skincare Center located?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "GV Skincare Center is at 23410 Grand Reserve Dr, Suite 302, Katy, TX 77494, in the Cinco Ranch area of Katy. We serve Katy, Cinco Ranch, Fulshear, Richmond, and west Houston, and we see clients by appointment Tuesday through Saturday."
          }
        },
        {
          "@type": "Question",
          "name": "What treatments does GV Skincare Center offer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We offer facial and body treatments including HydraFacial, dermaplaning, microdermabrasion, chemical peels, RF microneedling, microneedling, PRP, acne and anti-aging facials, back facials, body contouring, ultrasonic cavitation, lymphatic drainage massage, body wraps, and bridal packages."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need an appointment, and what are your hours?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, GV Skincare Center is by appointment only. Our hours are Tuesday through Saturday, 9:00 a.m. to 5:00 p.m., and we are closed Sunday and Monday. You can book online through our website or call (346) 257-4149."
          }
        },
        {
          "@type": "Question",
          "name": "How do I book an appointment at GV Skincare Center?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Book online through our website or call or text (346) 257-4149. If you are not sure which treatment is right for you, start with an in-person evaluation or a virtual consultation and we will recommend a plan for your skin."
          }
        },
        {
          "@type": "Question",
          "name": "Does GV Skincare Center offer payment plans?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. GV Skincare Center offers payment plan options so you can spread the cost of treatments and packages. Ask about current payment plans when you book, or see the Payment Plans page on our website for details."
          }
        },
        {
          "@type": "Question",
          "name": "Hablan espanol en GV Skincare Center?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Si. En GV Skincare Center atendemos en espanol e ingles. Gaby y el equipo te asesoran sobre el mejor tratamiento facial o corporal para tu piel. Llama o escribe al (346) 257-4149 para agendar tu cita."
          }
        }
